COMPOSE_PROJECT_NAME=sokolrock
TZ=Europe/Moscow

# Образ S-UI (подставьте актуальный тег с Docker Hub / ghcr.io вашего проекта)
SUI_IMAGE=PLACEHOLDER_REPLACE_WITH_ACTUAL_SUI_IMAGE

# Основной домен сайта (статика в ./html)
ROOT_DOMAIN=sokolrock.org
WWW_DOMAIN=www.sokolrock.org
# Панель S-UI
PANEL_DOMAIN=panel.sokolrock.org
# Транспортные поддомены (как в исходном Docker_S-UI-SAIT)
HY2_DOMAIN=hy2.sokolrock.org
VLESS_DOMAIN=vless.sokolrock.org

LETSENCRYPT_EMAIL=admin@sokolrock.org
LETSENCRYPT_STAGING=0

# Имя каталога в /etc/letsencrypt/live/ (совпадает с первым -d в certbot; обычно ROOT_DOMAIN)
CERT_LIVE_NAME=sokolrock.org
